# AI-Powered Job Recommendation System Environment Configurations

# Secret key for JWT session tokens (Change in production!)
SECRET_KEY=super-secret-key-change-in-production-1234567890

# Database URL Configurations
# For local SQLite development (default):
DATABASE_URL=sqlite:///./job_recommendation.db

# For Docker-compose / PostgreSQL deployment:
# DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/job_recommendation

# Resumes File Storage upload path
UPLOAD_DIR=uploads/resumes
